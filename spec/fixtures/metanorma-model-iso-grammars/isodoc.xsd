        <xs:annotation>
          <xs:documentation>Whether the designation is the same across languages, or language-specific</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="expression">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="name">
          <xs:annotation>
            <xs:documentation>The textual form of the designation</xs:documentation>
          </xs:annotation>
          <xs:complexType mixed="true">
            <xs:choice minOccurs="0" maxOccurs="unbounded">
              <xs:group ref="PureTextElement"/>
