  <xs:element name="grammar" type="Grammar">
    <xs:annotation>
      <xs:documentation>Grammatical information about the designation</xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:simpleType name="ExpressionDesignationType">
    <xs:annotation>
      <xs:documentation>Type of linguistic form used as designation</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="prefix">
        <xs:annotation>
          <xs:documentation>The form is a prefix</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="suffix">
        <xs:annotation>
          <xs:documentation>The form is a suffix</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="abbreviation">
        <xs:annotation>
          <xs:documentation>The form is an abbreviation</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="full">
        <xs:annotation>
          <xs:documentation>The form is a self-standing linguistic expression</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="AbbreviationType">
    <xs:annotation>
      <xs:documentation>Type of abbreviation, according to how it is formed</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="truncation">
        <xs:annotation>
          <xs:documentation>Abbrevation formed by truncating constituent words</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="acronym">
        <xs:annotation>
          <xs:documentation>Abbrevation formed from the initials of its constituent words, and pronounced as a new word</xs:documentation>
