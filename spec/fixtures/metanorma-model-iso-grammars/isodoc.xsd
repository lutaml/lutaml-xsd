            <xs:documentation>Realisation of a designation as a linguistic form</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element ref="letter-symbol">
          <xs:annotation>
            <xs:documentation>Realisation of a designation as a letter or symbol</xs:documentation>
          </xs:annotation>
        </xs:element>
