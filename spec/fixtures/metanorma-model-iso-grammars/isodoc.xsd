      </xs:enumeration>
      <xs:enumeration value="initialism">
        <xs:annotation>
          <xs:documentation>Abbrevation formed from the initials of its constituent words, and pronounced as a sequence of letters</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
    </xs:restriction>
  </xs:simpleType>
  <xs:complexType name="Grammar">
    <xs:annotation>
      <xs:documentation>Grammatical information about a designation</xs:documentation>
    </xs:annotation>
