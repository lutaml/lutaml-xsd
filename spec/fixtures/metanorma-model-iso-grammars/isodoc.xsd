        <xs:element minOccurs="0" ref="legal-statement">
          <xs:annotation>
            <xs:documentation>Preset templated text provided by the standardization body, providing the legal constraints and considerations around use of the document</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element minOccurs="0" ref="feedback-statement">
          <xs:annotation>
            <xs:documentation>Preset templated text provided by the standardization body, providing information on where feedback on the document may be addressed to</xs:documentation>
          </xs:annotation>
