  <xs:element name="copyright-statement" type="Content-Section"/>
  <xs:element name="license-statement" type="Content-Section"/>
  <xs:element name="legal-statement" type="Content-Section"/>
  <xs:element name="feedback-statement" type="Content-Section"/>
  <xs:element name="definitions">
    <xs:complexType>
      <xs:sequence>
        <xs:group minOccurs="0" ref="section-title">
