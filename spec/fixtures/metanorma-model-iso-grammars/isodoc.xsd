    <xs:complexType mixed="true">
      <xs:group maxOccurs="unbounded" ref="PureTextElement"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="usage-info">
    <xs:complexType mixed="true">
      <xs:group maxOccurs="unbounded" ref="PureTextElement"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="letter-symbol">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="name">
          <xs:annotation>
            <xs:documentation>The symbolic form of the designation</xs:documentation>
