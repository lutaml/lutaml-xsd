        </xs:sequence>
      </xs:sequence>
      <xs:attributeGroup ref="OptionalId"/>
      <xs:attributeGroup ref="LocalizedStringAttributes"/>
      <xs:attribute name="type">
        <xs:annotation>
          <xs:documentation>Semantic class of clause</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="obligation" type="ObligationType"/>
    </xs:complexType>
  </xs:element>
  <xs:group name="content">
    <xs:sequence>
      <xs:element name="clause" type="Content-Section"/>
    </xs:sequence>
  </xs:group>
  <xs:group name="abstract">
    <xs:annotation>
      <xs:documentation>Abstract of a document, presented as a clause</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="abstract" type="Content-Section"/>
    </xs:sequence>
  </xs:group>
  <xs:element name="acknowledgements" type="Content-Section"/>
  <xs:group name="content-subsection">
