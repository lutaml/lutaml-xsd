    <xs:restriction base="xs:token">
      <xs:enumeration value="letter">
        <xs:annotation>
          <xs:documentation>A letter, possibly subscripted or superscripted, intended to denote some property that it abbreviates</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="symbol">
        <xs:annotation>
          <xs:documentation>A non-letter, intended to represent some property</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="formula">
        <xs:annotation>
          <xs:documentation>A mathematical formula</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="equation">
        <xs:annotation>
          <xs:documentation>A mathematical equation (or inequation)</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
    </xs:restriction>
