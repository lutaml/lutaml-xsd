        <xs:annotation>
          <xs:documentation>The type of linguistic form used as designation</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="isInternational" type="xs:boolean">
        <xs:annotation>
          <xs:documentation>Whether the designation (typically an abbreviation) is the same across languages, or language-specific</xs:documentation>
        </xs:annotation>
      </xs:attribute>
