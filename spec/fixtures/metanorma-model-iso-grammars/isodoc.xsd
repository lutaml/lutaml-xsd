            <xs:element minOccurs="0" maxOccurs="unbounded" ref="terms"/>
            <xs:element minOccurs="0" ref="definitions"/>
          </xs:sequence>
        </xs:choice>
      </xs:sequence>
      <xs:attributeGroup ref="Section-Attributes"/>
      <xs:attribute name="type">
        <xs:annotation>
          <xs:documentation>Semantic class of clause</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="TermAttributes">
    <xs:attributeGroup ref="RequiredId"/>
    <xs:attributeGroup ref="LocalizedStringAttributes"/>
    <xs:attributeGroup ref="BlockAttributes"/>
  </xs:attributeGroup>
  <xs:element name="preferred" type="Designation"/>
  <xs:element name="admitted" type="Designation"/>
  <xs:element name="related">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="preferred" type="Designation">
          <xs:annotation>
            <xs:documentation>Preferred designation of the term related to the current term</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:choice>
          <xs:element ref="eref">
            <xs:annotation>
              <xs:documentation>Link to a definition of the term in a bibliographic entry</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="erefstack">
            <xs:annotation>
              <xs:documentation>Stack of links to a definition of the term in a bibliographic entry</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="xref">
            <xs:annotation>
              <xs:documentation>Link to a definition of the term in an element of the current document</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="termref">
            <xs:annotation>
              <xs:documentation>Link to a definition of the term in a termbase</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:choice>
      </xs:sequence>
      <xs:attribute name="type" use="required" type="RelatedTermType">
        <xs:annotation>
          <xs:documentation>Type of relation of term applicable</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:simpleType name="RelatedTermType">
    <xs:annotation>
      <xs:documentation>The relation of a term to the current term</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="deprecates">
        <xs:annotation>
          <xs:documentation>The current term deprecates the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="supersedes">
        <xs:annotation>
          <xs:documentation>The current term supersedes the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="narrower">
        <xs:annotation>
          <xs:documentation>The current term is narrower in denotation than the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="broader">
        <xs:annotation>
          <xs:documentation>The current term is broader in denotation than the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="equivalent">
        <xs:annotation>
          <xs:documentation>The current term is equivalent in denotation to the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="compare">
        <xs:annotation>
          <xs:documentation>The current term may be compared to the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="contrast">
        <xs:annotation>
          <xs:documentation>The current term is understood in contrast to the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="see">
        <xs:annotation>
          <xs:documentation>For a better understanding of the current term, one should see the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="seealso">
        <xs:annotation>
          <xs:documentation>For a better understanding of the current term, one should also see the related term</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
    </xs:restriction>
  </xs:simpleType>
  <xs:element name="deprecates" type="Designation"/>
  <xs:complexType name="Designation">
