      <xs:element name="clause" type="Content-Section"/>
    </xs:sequence>
  </xs:group>
  <xs:group name="clause">
    <xs:sequence>
      <xs:element name="clause" type="Clause-Section"/>
    </xs:sequence>
  </xs:group>
  <xs:complexType name="Annex-Section">
    <xs:annotation>
